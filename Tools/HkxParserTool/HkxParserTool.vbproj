<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>HkxParserTool</RootNamespace>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
  </PropertyGroup>

  <!-- Link HKX parser sources directly (avoids Wardrobe_Manager transitive deps) -->
  <ItemGroup>
    <Compile Include="..\..\Wardrobe_Manager\HkxPackfileParser.vb">
      <Link>HkxPackfileParser.vb</Link>
    </Compile>
    <Compile Include="..\..\Wardrobe_Manager\HkxObjectGraphParser.vb">
      <Link>HkxObjectGraphParser.vb</Link>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\NiflySharp\NiflySharp\NiflySharp.csproj" />
  </ItemGroup>
</Project>
